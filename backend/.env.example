# ─────────────────────────────────────────────────────────────
# IT Ticketing System — Environment Variables
# Copy file ini ke .env dan isi nilainya
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database ──────────────────────────────────────────────────
# Local:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/it_ticketing"
# Railway (otomatis terisi oleh Railway jika pakai plugin PostgreSQL):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── JWT ───────────────────────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_MINIMAL_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_STRING_LAIN_MINIMAL_64_KARAKTER
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── File Upload ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ── Email (SMTP) ───────────────────────────────────────────────
# Gunakan Gmail App Password (bukan password biasa)
# Aktifkan di: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=IT Support <noreply@company.com>

# ── CORS — URL Frontend ────────────────────────────────────────
# Vercel: https://nama-project.vercel.app
# Local:  http://localhost:3000
FRONTEND_URL=https://nama-project.vercel.app

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── SLA Cron (setiap jam) ─────────────────────────────────────
SLA_CRON_SCHEDULE=0 * * * *
