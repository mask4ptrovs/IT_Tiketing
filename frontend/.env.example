# ─────────────────────────────────────────────────────────────
# IT Ticketing Frontend — Environment Variables
# Di Vercel: tambahkan di Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# URL backend API (Railway)
# Contoh: https://it-tiketing-production.up.railway.app/api
NEXT_PUBLIC_API_URL=https://YOUR_RAILWAY_APP.up.railway.app/api

# URL Socket.io (sama dengan backend, tanpa /api)
NEXT_PUBLIC_SOCKET_URL=https://YOUR_RAILWAY_APP.up.railway.app
